# Local development values for the Discord Chat Bridge project.
# Do not commit a real .env file with secrets.
#
# The Home Assistant integration itself will store configured values in a
# config entry. These variables exist for local scripts, manual testing, and
# future developer utilities.

DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=123456789012345678
DISCORD_CHAT_BRIDGE_API_KEY=replace_with_a_long_random_secret

# Optional values for local development.
HOME_ASSISTANT_URL=http://127.0.0.1:8123
HOME_ASSISTANT_EXTERNAL_URL=https://your-ha-url.example.com
